# Persistent chore timers
# Lives at ~/.claude/productivity/chore_timers.yaml
# Survives session resets — entries are removed when the chore is marked done,
# not at session end.
#
# Two ways to add an entry:
#   1. duration_minutes: N   — Python assigns an id and converts to end_time on next load
#   2. end_time: ISO         — set explicitly (Python preserves it as-is)
#
# Claude adds entries when the user mentions a chore (writing duration_minutes is
# the normal path). When the user confirms a chore is done, Claude adds the id
# (e.g. chore:1) to completed_ids in session.yaml — Python removes the entry on
# next load.
#
# To delay an active chore, write {delay: N} (minutes) under extensions in
# session.yaml using the same chore:N id.

chore_timers:
  - name: Washing machine
    duration_minutes: 90

  - name: Dishwasher
    duration_minutes: 60
